# ---------------------------------------------------------------------------
# AI-Powered Knowledge Retrieval Agent — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- LLM / Embedding provider keys -----------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
PINECONE_API_KEY=your-pinecone-api-key-here

# --- Pinecone (production vector store) -------------------------------------
PINECONE_INDEX_NAME=knowledge-retrieval-agent
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=default
PINECONE_UPSERT_BATCH_SIZE=100

# --- Embeddings -------------------------------------------------------------
# EMBEDDING_PROVIDER: openai | huggingface | local
#   local = deterministic offline embeddings (no API key, for dev/CI/tests)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# --- Chunking ---------------------------------------------------------------
CHUNK_SIZE=768
CHUNK_OVERLAP=96
MIN_CHUNK_WORDS=20
CHUNKING_STRATEGY=recursive

# --- Retrieval --------------------------------------------------------------
RETRIEVAL_K=6
RETRIEVAL_FETCH_K=20
RETRIEVAL_LAMBDA_MULT=0.5
RETRIEVAL_STRATEGY=mmr
SCORE_THRESHOLD=0.72
ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- LLM generation ---------------------------------------------------------
# LLM_PROVIDER: openai | local
#   local = deterministic extractive answerer (no API key, for dev/CI/tests)
LLM_PROVIDER=local
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LOW_CONFIDENCE_THRESHOLD=0.65

# --- Vector store selection -------------------------------------------------
# VECTOR_STORE: chroma | pinecone
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=knowledge_base_dev

# --- API service ------------------------------------------------------------
FASTAPI_API_KEY=your-fastapi-api-key-here
API_HOST=0.0.0.0
API_PORT=8080
# REQUIRE_API_KEY: enforce X-API-Key header (set true in production)
REQUIRE_API_KEY=false

# --- Metadata DB (ingestion/query audit log) --------------------------------
# Default sqlite is zero-config for dev. Use a postgres URL in production.
METADATA_DB_URL=sqlite:///./metadata.sqlite3

# --- Observability ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_JSON=true
